# ============================================================
# 抖音视频分析工具 - 环境变量配置
# 复制本文件为 .env 后填入实际值
# ============================================================

# ------------------------------------------------------------------
# 数据库（MySQL）- 解析结果存储
# 格式: mysql://用户名:密码@主机:端口/数据库名
# ------------------------------------------------------------------
DATABASE_URL=mysql://root:password@localhost:3306/douyin_analyzer

# ------------------------------------------------------------------
# Kimi OAuth 认证（如需要用户登录功能）
# 在 https://developer.kimi.com 创建应用获取
# ------------------------------------------------------------------
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here

# ------------------------------------------------------------------
# 前端认证地址（Vercel 部署时自动配置）
# ------------------------------------------------------------------
VITE_KIMI_AUTH_URL=https://your-app.vercel.app
VITE_APP_ID=your_app_id_here
